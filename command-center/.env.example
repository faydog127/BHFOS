# Copy to `.env` and/or `.env.local` (recommended for secrets).
# Never commit real credentials.

########################################
# Supabase (frontend runtime)
########################################
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

########################################
# App API endpoints (frontend runtime)
########################################
VITE_API_BASE_URL=https://api.example.com
VITE_WS_URL=wss://ws.example.com
VITE_TENANT_ID=tvg

########################################
# Supabase (CLI / admin scripts)
########################################
SUPABASE_PROJECT_REF=YOUR_PROJECT_REF
SUPABASE_ACCESS_TOKEN=sbp_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

########################################
# Hostinger (deployment)
########################################
HOSTINGER_API_TOKEN=...
HOSTINGER_DOMAIN=app.bhfos.com
# HOSTINGER_ARCHIVE=c:\\BHFOS\\command-center\\tmp\\dist-deploy-YYYYMMDD-HHMMSS.zip
