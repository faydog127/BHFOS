{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "result_schema_v2.json",
  "title": "Per Test Result Schema v2",
  "type": "object",
  "required": [
    "schema_version",
    "test_id",
    "test_name",
    "lane",
    "status",
    "severity",
    "runtime_ms",
    "environment",
    "fixture_id",
    "pre_state",
    "expected",
    "actual",
    "invariant_results",
    "workers",
    "artifacts",
    "artifact_completeness",
    "promotion_gate",
    "redaction_policy"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "2.0" },
    "test_id": { "type": "string" },
    "test_name": { "type": "string" },
    "lane": { "type": "string", "enum": ["fast", "full", "race", "soak"] },
    "iteration": { "type": ["integer", "null"], "minimum": 1 },
    "status": { "type": "string", "enum": ["PASS", "FAIL", "FLAKY"] },
    "classification": {
      "type": ["string", "null"],
      "enum": [
        "business_logic_defect",
        "concurrency_defect",
        "migration_defect",
        "test_harness_defect",
        "environment_config_defect",
        null
      ]
    },
    "failure_mode": {
      "type": ["string", "null"],
      "enum": ["deterministic", "intermittent", "unknown_insufficient_runs", null]
    },
    "failure_signature": { "type": ["string", "null"] },
    "outcome_type": {
      "type": ["string", "null"],
      "enum": [
        "expected_single_winner",
        "unexpected_double_success",
        "unexpected_double_failure",
        "invariant_mismatch",
        null
      ]
    },
    "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
    "runtime_ms": { "type": "integer", "minimum": 0 },
    "commit_hash": { "type": ["string", "null"] },
    "confidence_score": { "type": ["integer", "null"], "minimum": 0, "maximum": 100 },
    "confidence_score_delta": { "type": ["integer", "null"] },
    "environment": {
      "type": "object",
      "required": ["runner", "php_version", "db_engine", "db_version"],
      "properties": {
        "runner": { "type": "string" },
        "php_version": { "type": "string" },
        "db_engine": { "type": "string" },
        "db_version": { "type": "string" },
        "isolation_level": { "type": ["string", "null"] },
        "php_image": { "type": ["string", "null"] },
        "db_container": { "type": ["string", "null"] },
        "cpu_limit": { "type": ["string", "null"] },
        "memory_limit_mb": { "type": ["integer", "null"] }
      },
      "additionalProperties": false
    },
    "fixture_id": { "type": "string" },
    "pre_state": {
      "type": "object",
      "description": "Minimal asserted starting condition for the test fixture.",
      "additionalProperties": true
    },
    "expected": {
      "type": "object",
      "required": ["final_state", "invariants"],
      "properties": {
        "success_count": { "type": ["integer", "null"], "minimum": 0 },
        "failure_count": { "type": ["integer", "null"], "minimum": 0 },
        "expected_failure_codes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "final_state": {
          "type": "object",
          "additionalProperties": true
        },
        "invariants": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "actual": {
      "type": "object",
      "required": ["final_state"],
      "properties": {
        "success_count": { "type": ["integer", "null"], "minimum": 0 },
        "failure_count": { "type": ["integer", "null"], "minimum": 0 },
        "failure_codes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "db_error_family": { "type": ["string", "null"] },
        "final_state": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "invariant_results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "passed", "details"],
        "properties": {
          "name": { "type": "string" },
          "passed": { "type": "boolean" },
          "details": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "workers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["worker_id", "status", "duration_ms"],
        "properties": {
          "worker_id": { "type": "string" },
          "status": { "type": "string", "enum": ["success", "failed", "timeout", "unknown"] },
          "error_code": { "type": ["string", "null"] },
          "duration_ms": { "type": "integer", "minimum": 0 },
          "connection_id": { "type": ["string", "null"] },
          "transaction_start_ts": { "type": ["string", "null"], "format": "date-time" }
        },
        "additionalProperties": false
      }
    },
    "artifacts": {
      "type": "object",
      "properties": {
        "stdout_path": { "type": ["string", "null"] },
        "stderr_path": { "type": ["string", "null"] },
        "db_snapshot_path": { "type": ["string", "null"] },
        "worker_results_path": { "type": ["string", "null"] },
        "timing_trace_path": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "artifact_completeness": {
      "type": "object",
      "required": ["worker_stdout", "worker_stderr", "db_snapshot", "timing_trace"],
      "properties": {
        "worker_stdout": { "type": "boolean" },
        "worker_stderr": { "type": "boolean" },
        "db_snapshot": { "type": "boolean" },
        "timing_trace": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "promotion_gate": {
      "type": "object",
      "required": ["lane_green", "merge_recommended", "deploy_recommended", "reason"],
      "properties": {
        "lane_green": { "type": "boolean" },
        "merge_recommended": { "type": "boolean" },
        "deploy_recommended": { "type": "boolean" },
        "reason": { "type": "string" }
      },
      "additionalProperties": false
    },
    "redaction_policy": {
      "type": "object",
      "required": ["customer_ids_masked", "billing_case_ids_masked", "raw_payloads_excluded"],
      "properties": {
        "customer_ids_masked": { "type": "boolean" },
        "billing_case_ids_masked": { "type": "boolean" },
        "raw_payloads_excluded": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "notes": { "type": ["string", "null"] }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "FAIL" } } },
      "then": {
        "required": ["failure_mode"]
      }
    },
    {
      "if": {
        "properties": {
          "status": { "const": "FAIL" },
          "artifact_completeness": {
            "properties": {
              "worker_stdout": { "const": true },
              "worker_stderr": { "const": true },
              "db_snapshot": { "const": true },
              "timing_trace": { "const": true }
            },
            "required": ["worker_stdout", "worker_stderr", "db_snapshot", "timing_trace"]
          }
        },
        "required": ["status", "artifact_completeness"]
      },
      "then": {
        "required": ["classification"],
        "properties": {
          "classification": { "not": { "type": "null" } }
        }
      }
    }
  ],
  "additionalProperties": false
}
